project     = "sim-prov"
environment = "prod"
region      = "ap-south-1"

vpc_cidr           = "10.40.0.0/16"
availability_zones = ["ap-south-1a", "ap-south-1b", "ap-south-1c"]

eks_version             = "1.29"
eks_node_instance_types = ["t3.large"]
eks_node_min_size       = 3
eks_node_desired_size   = 3
eks_node_max_size       = 6

db_name              = "simprov"
db_username          = "simprov"
# Do NOT commit a real password — pipeline sources this from Vault:
#   vault kv get -field=password secret/sim-prov/db
db_password          = "REPLACE_ME_FROM_VAULT"
db_instance_class    = "db.t3.medium"
db_allocated_storage = 50

tags = {
  Owner      = "sayuj@itm-skills.edu.in"
  CostCenter = "telco-platform"
  Compliance = "trai-gdpr"
  ManagedBy  = "terraform"
}
