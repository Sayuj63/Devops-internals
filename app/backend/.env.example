ENV=dev
LOG_LEVEL=INFO
LOG_FORMAT=pretty

DATABASE_URL=postgresql+asyncpg://sim:sim@localhost:5432/sim_provisioning

HLR_BASE_URL=http://localhost:9090
HLR_TIMEOUT_SECONDS=2.0
HLR_MAX_RETRIES=3

VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

MSISDN_COUNTRY_CODE=+91
REQUEST_ID_HEADER=X-Request-ID

# Mock HLR tuning (only consumed by mock_hlr/main.py)
HLR_FAILURE_RATE=0.05
HLR_MIN_LATENCY_MS=50
HLR_MAX_LATENCY_MS=200
