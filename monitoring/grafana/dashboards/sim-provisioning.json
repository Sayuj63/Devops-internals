{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "SIMs by status",
      "id": 1,
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum by (status) (sim_count_by_status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "SIM status distribution",
      "id": 2,
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum by (status) (sim_count_by_status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "MSISDN pool remaining",
      "id": 3,
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 1000 },
              { "color": "green",  "value": 5000 }
            ]
          },
          "min": 0,
          "max": 100000,
          "unit": "short"
        }
      },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "sim:msisdn_pool_remaining", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Activation rate (req/s)",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum(rate(sim_activations_total[5m]))",                      "legendFormat": "all",     "refId": "A" },
        { "expr": "sum(rate(sim_activations_total{result=\"success\"}[5m]))", "legendFormat": "success", "refId": "B" },
        { "expr": "sum(rate(sim_activations_total{result=\"failure\"}[5m]))", "legendFormat": "failure", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Activation latency p50 / p95 / p99",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "sim:activation_latency_seconds:p50", "legendFormat": "p50", "refId": "A" },
        { "expr": "sim:activation_latency_seconds:p95", "legendFormat": "p95", "refId": "B" },
        { "expr": "sim:activation_latency_seconds:p99", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "stat",
      "title": "HLR call success rate (5m)",
      "id": 6,
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "green",  "value": 0.99 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [ { "expr": "sim:hlr_call_success_rate:5m", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "DB connections in use",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "sum by (datname) (pg_stat_activity_count{datname=\"simprov\"})", "legendFormat": "{{datname}} active", "refId": "A" },
        { "expr": "pg_settings_max_connections", "legendFormat": "max_connections", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pod CPU (api)",
      "id": 8,
      "gridPos": { "h": 8, "w": 9, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"sim-prov\",container=\"api\"}[5m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pod memory (api)",
      "id": 9,
      "gridPos": { "h": 8, "w": 9, "x": 9, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"sim-prov\",container=\"api\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Recent alerts",
      "id": 10,
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "ALERTS{alertstate=\"firing\"}", "instant": true, "refId": "A", "format": "table" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["sim-prov", "telecom", "operations"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "SIM Provisioning — Operations",
  "uid": "sim-prov-ops",
  "version": 1,
  "weekStart": ""
}
